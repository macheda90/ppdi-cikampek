// Prisma schema for PPDI Kecamatan Cikampek
// SQLite database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  name         String
  email        String?  @unique
  role         String   @default("PENGURUS") // SUPER_ADMIN | ADMIN | EDITOR | PENGURUS
  avatar       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  pengurus     Pengurus?
  auditLogs    AuditLog[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// ==================== MASTER DATA ====================

model Desa {
  id          String     @id @default(cuid())
  namaDesa    String
  alamat      String?
  kecamatan   String     @default("Cikampek")
  kabupaten   String     @default("Karawang")
  provinsi    String     @default("Jawa Barat")
  kodePos     String?
  kepalaDesa  String?
  kontak      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pengurus    Pengurus[]

  @@map("desa")
}

model Jabatan {
  id          String     @id @default(cuid())
  namaJabatan String
  urutan      Int        @default(99)
  kategori    String     @default("PENGURUS") // PIMPINAN | BIDANG | ANGGOTA
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pengurus    Pengurus[]

  @@map("jabatan")
}

model Pengurus {
  id            String   @id @default(cuid())
  nipd          String?
  namaLengkap   String
  nik           String?
  tempatLahir   String?
  tanggalLahir  DateTime?
  jenisKelamin  String?  // L | P
  foto          String?
  desaId        String?
  desa          Desa?    @relation(fields: [desaId], references: [id], onDelete: SetNull)
  jabatanId     String?
  jabatan       Jabatan? @relation(fields: [jabatanId], references: [id], onDelete: SetNull)
  masaJabatan   String?
  alamat        String?
  noHp          String?
  email         String?
  statusAktif   Boolean  @default(true)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([desaId])
  @@index([jabatanId])
  @@map("pengurus")
}

// ==================== CONTENT MANAGEMENT ====================

model Kategori {
  id        String   @id @default(cuid())
  nama      String
  tipe      String   @default("BERITA") // BERITA | ARTIKEL | DOWNLOAD
  slug      String
  createdAt DateTime @default(now())

  @@unique([tipe, slug])
  @@map("kategori")
}

model Berita {
  id              String    @id @default(cuid())
  judul           String
  slug            String    @unique
  kategori        String    @default("Umum")
  thumbnail       String?
  ringkasan       String?
  isi             String
  penulis         String?
  status          String    @default("DRAFT") // DRAFT | PUBLISH
  tags            String?
  seoTitle        String?
  metaDescription String?
  metaKeywords    String?
  featured        Boolean   @default(false)
  viewCount       Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, publishedAt])
  @@map("berita")
}

model Artikel {
  id              String    @id @default(cuid())
  judul           String
  slug            String    @unique
  kategori        String    @default("Umum")
  thumbnail       String?
  ringkasan       String?
  isi             String
  penulis         String?
  tags            String?
  seoTitle        String?
  metaDescription String?
  metaKeywords    String?
  viewCount       Int       @default(0)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([publishedAt])
  @@map("artikel")
}

model Kegiatan {
  id              String   @id @default(cuid())
  namaKegiatan    String
  slug            String   @unique
  tanggal         DateTime
  lokasi          String?
  penanggungJawab String?
  deskripsi       String?
  fotos           String?  // JSON string of image URLs
  videoUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("kegiatan")
}

model Agenda {
  id            String   @id @default(cuid())
  namaAgenda    String
  tanggalMulai  DateTime
  tanggalSelesai DateTime?
  lokasi        String?
  deskripsi     String?
  status        String   @default("MENDATANG") // MENDATANG | BERLANGSUNG | SELESAI
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("agenda")
}

model Galeri {
  id          String   @id @default(cuid())
  judul       String
  kategori    String   @default("FOTO") // FOTO | VIDEO
  url         String
  thumbnail   String?
  deskripsi   String?
  createdAt   DateTime @default(now())

  @@map("galeri")
}

model Download {
  id            String   @id @default(cuid())
  judul         String
  kategori      String   @default("DOKUMEN") // SURAT_EDARAN | AD_ART | FORMULIR | DOKUMEN
  fileUrl       String
  fileSize      String?
  fileType      String?
  deskripsi     String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("download")
}

// ==================== SETTINGS ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  category  String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("setting")
}

// ==================== CONTACT MESSAGES ====================

model PesanKontak {
  id        String   @id @default(cuid())
  nama      String
  email     String
  telepon   String?
  subjek    String
  pesan     String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("pesan_kontak")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName  String?
  action    String   // LOGIN | LOGOUT | CREATE | UPDATE | DELETE
  module    String
  detail    String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}
